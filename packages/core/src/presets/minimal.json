{
  "schemaVersion": 1,
  "name": "Minimal",
  "values": {
    "page.size": "A4",
    "page.marginTop": 24,
    "page.marginRight": 24,
    "page.marginBottom": 24,
    "page.marginLeft": 24,
    "body.fontFamily": "Inter, system-ui, sans-serif",
    "body.fontSize": 11,
    "body.color": "#222222",
    "body.lineHeight": 1.7,
    "h1.fontSize": 26,
    "h1.fontWeight": 600,
    "h1.color": "#111111",
    "h2.fontSize": 20,
    "h2.fontWeight": 600,
    "h2.color": "#111111",
    "h3.fontSize": 16,
    "h3.color": "#111111",
    "link.color": "#111111",
    "link.textDecoration": "underline",
    "codeInline.color": "#111111",
    "codeInline.background": "#f4f4f5",
    "codeBlock.fontSize": 10,
    "codeBlock.background": "#1e1e1e",
    "codeBlock.borderRadius": 4,
    "table.headerBg": "#ffffff",
    "table.headerColor": "#111111",
    "table.borderColor": "#e4e4e7",
    "table.borderMode": "horizontal",
    "table.stripe": false,
    "blockquote.borderLeftWidth": 2,
    "blockquote.borderLeftColor": "#d4d4d8",
    "blockquote.color": "#52525b",
    "blockquote.fontStyle": "normal",
    "blockquote.paddingLeft": 14
  }
}
