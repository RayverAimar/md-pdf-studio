// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generateCss — golden + layering > matches the golden snapshot for the Editorial preset 1`] = `
"@page {
  margin-bottom: 22mm;
  margin-left: 20mm;
  margin-right: 20mm;
  margin-top: 22mm;
  size: A4;
}
:root {
  --shiki-background: #0f172a;
  --shiki-token-comment: #64748b;
  --shiki-foreground: #e2e8f0;
  --shiki-token-function: #82aaff;
  --shiki-token-keyword: #c792ea;
  --shiki-token-constant: #f78c6c;
  --shiki-token-string: #a5d6a7;
  --mdp-table-border: #cbd5e1;
  --mdp-table-stripe: #f8fafc;
}
.mdp-blockquote { border-left-color: #cbd5e1; }
.mdp-blockquote { border-left-width: 4px; }
.mdp-blockquote { color: #475569; }
.mdp-blockquote { font-style: italic; }
.mdp-blockquote { padding-left: 16px; }
.mdp { color: #1a1a1a; }
.mdp { font-family: Georgia, 'Times New Roman', serif; }
.mdp { font-size: 11pt; }
.mdp { line-height: 1.7; }
.mdp-codeblock { border-radius: 8px; }
.mdp-codeblock { font-size: 9.5pt; }
.mdp-codeblock { line-height: 1.5; }
.mdp-codeblock { padding: 14px; }
.mdp-code-inline { background-color: #f1f5f9; }
.mdp-code-inline { color: #be123c; }
.mdp-code-inline { font-family: JetBrains Mono, ui-monospace, monospace; }
.mdp-code-inline { font-size: 0.9em; }
.mdp-h1 { color: #111827; }
.mdp-h1 { font-size: 30pt; }
.mdp-h1 { font-weight: 700; }
.mdp-h1 { margin-bottom: 14pt; }
.mdp-h1 { margin-top: 28pt; }
.mdp-h2 { color: #111827; }
.mdp-h2 { font-size: 22pt; }
.mdp-h2 { font-weight: 700; }
.mdp-h2 { margin-bottom: 10pt; }
.mdp-h2 { margin-top: 20pt; }
.mdp-h3 { color: #111827; }
.mdp-h3 { font-size: 17pt; }
.mdp-h3 { font-weight: 700; }
.mdp-h3 { margin-bottom: 8pt; }
.mdp-h3 { margin-top: 16pt; }
.mdp-link { color: #1d4ed8; }
.mdp-link { font-weight: 400; }
.mdp-link { text-decoration: underline; }
.mdp { background-color: #ffffff; }
.mdp-table td, .mdp-table th { padding-inline: 10px; }
.mdp-table td, .mdp-table th { padding-block: 6px; }
.mdp-table th { background-color: #f1f5f9; }
.mdp-table th { color: #0f172a; }
.mdp-table tr { border-bottom: 1px solid var(--mdp-table-border); }
.mdp-table tbody tr:nth-child(even) { background: var(--mdp-table-stripe); }"
`;
