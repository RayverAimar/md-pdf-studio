{
  "name": "md-pdf-studio",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @md-pdf-studio/web dev",
    "dev:desktop": "pnpm --filter @md-pdf-studio/desktop dev",
    "dev:app": "concurrently -k -n web,desktop -c blue,magenta \"pnpm dev:web\" \"wait-on http://localhost:3000 && pnpm dev:desktop\"",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "fonts:embed": "node scripts/embed-fonts.mjs",
    "icons:gen": "node scripts/gen-icons.mjs",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "concurrently": "10.0.0",
    "turbo": "2.9.16",
    "typescript": "6.0.3",
    "wait-on": "9.0.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
