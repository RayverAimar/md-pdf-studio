{
  "name": "@md-pdf-studio/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.mjs",
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "node esbuild.mjs && electron .",
    "start": "electron .",
    "typecheck": "tsc",
    "test:integration": "node esbuild.mjs integration/renderPort.integration.ts && electron dist/renderPort.integration.mjs"
  },
  "build": {
    "appId": "com.burhum.mdpdfstudio",
    "productName": "md-pdf-studio",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icon.*"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Office"
    }
  },
  "dependencies": {
    "@md-pdf-studio/core": "workspace:*",
    "@md-pdf-studio/render": "workspace:*",
    "@md-pdf-studio/ui": "workspace:*",
    "pdfjs-dist": "6.0.227"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "electron": "42.3.0",
    "esbuild": "0.28.0",
    "typescript": "6.0.3"
  }
}
