{
  "name": "@md-pdf-studio/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Visual Markdown to PDF editor with granular, schema-driven styling",
  "author": {
    "name": "Rayver Muñoz Curi",
    "email": "ragi@burhum.com"
  },
  "main": "dist/main.mjs",
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "node esbuild.mjs && electron .",
    "start": "electron .",
    "dist": "node esbuild.mjs && electron-builder",
    "typecheck": "tsc",
    "test:integration": "node esbuild.mjs integration/renderPort.integration.ts && electron dist/renderPort.integration.mjs"
  },
  "build": {
    "appId": "com.burhum.mdpdfstudio",
    "productName": "md-pdf-studio",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icon.*"
    ],
    "publish": {
      "provider": "github",
      "owner": "RayverAimar",
      "repo": "md-pdf-studio"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Office",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "@md-pdf-studio/core": "workspace:*",
    "@md-pdf-studio/render": "workspace:*",
    "@md-pdf-studio/ui": "workspace:*",
    "pdfjs-dist": "6.0.227",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "electron": "42.3.0",
    "electron-builder": "26.8.1",
    "electron-updater": "6.8.3",
    "esbuild": "0.28.0",
    "typescript": "6.0.3"
  }
}
